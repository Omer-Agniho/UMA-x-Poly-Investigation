ect and prevent manipulation."},{question:"How do I report suspicious activity?",answer:"If you notice suspicious trading activity, you can report it through our support channels or by using the report button on the relevant market page."},{question:"Is there a limit to how much I can trade?",answer:"There may be position limits on certain markets to ensure market integrity. Check individual market details for any applicable limits."}];function Y(e){let l,i,a,n,o,c,u,m,d,x,h=(0,s.c)(27),{name:f,logo:g,score:v,probability:y,color:b}=e;h[0]!==g||h[1]!==f?(l=g&&(0,t.jsx)("div",{className:"relative size-10 shrink-0 overflow-hidden sm:max-lg:size-7",children:(0,t.jsx)(r.default,{src:g,alt:f,fill:!0,sizes:"40px",className:"object-contain"})}),h[0]=g,h[1]=f,h[2]=l):l=h[2],h[3]!==f?(i=(0,t.jsx)("span",{className:"min-w-0 flex-1 truncate text-[14px] sm:max-lg:text-[12px] sm:max-lg:leading-4 lg:text-[16px] font-semibold leading-5 text-white",children:f}),h[3]=f,h[4]=i):i=h[4],h[5]!==v?(a=void 0!==v&&(0,t.jsx)("span",{className:"w-10 text-center text-[14px] sm:max-lg:w-7 sm:max-lg:text-[12px] lg:text-[16px] font-semibold leading-5 text-white/90",children:v}),h[5]=v,h[6]=a):a=h[6],h[7]!==y?(n=y>0&&y<100&&(0,t.jsxs)("span",{className:"text-[11px] sm:max-lg:text-[10px] lg:text-[12px] font-medium leading-4 text-white/40 tabular-nums",children:[(100/y).toFixed(2),"x"]}),h[7]=y,h[8]=n):n=h[8],h[9]!==y?(o=(0,t.jsx)("div",{className:"flex h-10 w-[72px] items-center justify-center rounded-full bg-white/5 sm:max-lg:h-7 sm:max-lg:w-14",children:(0,t.jsx)(p.AnimatedNumber,{value:y,suffix:"%",minimumFractionDigits:0,maximumFractionDigits:0,className:"text-[14px] sm:max-lg:text-[12px] lg:text-[16px] font-semibold leading-5 text-white tabular-nums"})}),h[9]=y,h[10]=o):o=h[10],h[11]!==a||h[12]!==n||h[13]!==o?(c=(0,t.jsxs)("div",{className:"flex shrink-0 items-center gap-3 sm:max-lg:gap-1.5",children:[a,n,o]}),h[11]=a,h[12]=n,h[13]=o,h[14]=c):c=h[14],h[15]!==i||h[16]!==c?(u=(0,t.jsxs)("div",{c